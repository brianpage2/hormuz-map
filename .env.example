# Public client-side variables
# AISStream WebSocket API: https://aisstream.io/
NEXT_PUBLIC_AISSTREAM_API_KEY=
NEXT_PUBLIC_SITE_URL=https://map.yourdomain.com

# Optional public map settings
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png
NEXT_PUBLIC_HORMUZ_LAT=26.5833
NEXT_PUBLIC_HORMUZ_LNG=56.2500
NEXT_PUBLIC_DEFAULT_ZOOM=8

# Optional public analytics/ads
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Server-only integration keys
VESSELFINDER_CONTAINER_API_KEY=
VESSELFINDER_FLEET_API_KEY=
VESSELFINDER_AIS_USERKEY=
UPA_WORLD_PORTS_API_KEY=

# Server-only secret
REVALIDATION_SECRET=
